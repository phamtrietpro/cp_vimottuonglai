#include <bits/stdc++.h>
using namespace std;

const int maxn = 1e3 + 5;
int f[maxn][maxn];
int main()
{
    freopen("QBSTR.INP","r",stdin);
    freopen("QBSTR.OUT","w",stdout);
    string s, t;
    cin>>s>>t;
    int n = s.length();
    int m = t.length();
    for (int i = 1; i <= n; i++)
    {
        for(int j = 1; j <= m; j++)
        {
            if (s[i - 1] == t[j - 1])
            {
                f[i][j] = f[i - 1][j - 1] + 1;
            }
            else
            {
                f[i][j] = max(f[i - 1][j], f[i][j - 1]);
            }
        }
    }
    cout << f[n][m] << endl;
    return 0;
}
