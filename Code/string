#include <bits/stdc++.h>
using namespace std;

const int maxn = 1e3 + 5;
int dp[maxn][maxn];
int main()
{
    freopen("STRING.INP","r",stdin);
    freopen("STRING.OUT","w",stdout);
    string s,t;
    cin>>s>>t;
    int n = s.length();
    int m = t.length();
    for(int i = 0;i<=n;i++)
    {
        for(int j = 0;j<=m;j++)
        {
            if (i == 0)
            {
                dp[i][j] = j;
            }
            else if(j == 0)
            {
                dp[i][j] = i;
            }
            else if(s[i - 1] == t[j - 1])
            {
                dp[i][j] = dp[i - 1][j - 1];
            }
            else
            {
                dp[i][j] = 1 + min({dp[i - 1][j - 1], dp[i - 1][j], dp[i][j - 1]});
            }
        }
    }
    cout << dp[n][m] << endl;
    return 0;
}
