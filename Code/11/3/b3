#include <bits/stdc++.h>
using namespace std;

int s(int n) {
    int sum = 0;
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) {
            if (i * i == n) sum += i;
            else sum += i + n / i;
        }
    }
    return sum;
}


int main() 
{
    int m,n;
    cin>>m>>n;
    if(s(m) == s(n)) cout<<"YES";
    else cout<<"NO";
    return 0;
}
